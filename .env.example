# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-key-here

# ── Security ──────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────
# Local SQLite (dev, auto-created):
DATABASE_URL=sqlite:///./saas.db

# PostgreSQL (production / Docker):
# DATABASE_URL=postgresql://agentai:password@localhost:5432/agentai

# ── Docker Compose ────────────────────────────────────────────
POSTGRES_PASSWORD=secret
PGADMIN_PASSWORD=admin

# ── CORS ──────────────────────────────────────────────────────
# In production, set to your Render URL (no trailing slash):
# ALLOWED_ORIGINS=https://agentai-api.onrender.com
# Leave empty to allow all origins (dev mode — no credentials)
ALLOWED_ORIGINS=

# ── App ───────────────────────────────────────────────────────
APP_NAME=AgentAI Platform
APP_VERSION=2.0.0
DEBUG=false
